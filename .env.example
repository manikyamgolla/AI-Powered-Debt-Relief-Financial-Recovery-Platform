# --- App ---
APP_NAME="AI-Powered Debt Relief & Financial Recovery Platform"
ENV=production
DEBUG=false

# --- Database ---
# For local dev, SQLite is fine. Switch to Postgres for production:
# DATABASE_URL=postgresql+psycopg2://debtrelief:changeme@db:5432/debtrelief
DATABASE_URL=sqlite:///./data/debt_relief.db

# --- Auth ---
JWT_SECRET_KEY=replace_this_with_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Google Gemini ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
AI_REQUEST_TIMEOUT_SECONDS=20
